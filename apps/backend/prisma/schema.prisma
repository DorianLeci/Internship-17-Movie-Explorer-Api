generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CrewRole {
  DIRECTOR        @map("Director")
  PRODUCER        @map("Producer")
  WRITER          @map("Writer")
  EDITOR          @map("Editor")
  COMPOSER        @map("Composer")
  CINEMATOGRAPHER @map("Cinematographer")
}

enum GenreEnum {
  ACTION    @map("Action")
  ADVENTURE @map("Adventure")
  ANIMATION @map("Animation")
  COMEDY    @map("Comedy")
  CRIME     @map("Crime")
  DOCUMENTARY @map("Documentary")
  DRAMA     @map("Drama")
  FAMILY    @map("Family")
  FANTASY   @map("Fantasy")
  HISTORY   @map("History")
  HORROR    @map("Horror")
  MUSIC     @map("Music")
  MYSTERY   @map("Mystery")
  ROMANCE   @map("Romance")
  SCI_FI @map("Sci Fi")
  THRILLER  @map("Thriller")
  WAR       @map("War")
  WESTERN   @map("Western")
}

enum Role{
  USER
  ADMIN
}

model User{
  id Int @id @default(autoincrement())
  email String @unique
  password String
  favorites Favorite[]
  role Role @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model Movie{
  id Int @id @default(autoincrement())
  title String
  description String
  runtime Int  
  rating Float
  popularity Float
  posterUrl String?
  trailerKey String?
  releaseDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  genres Genre[] @relation("MovieGenres")

  favorites Favorite[]
  topCast TopCast[]
  topCrew TopCrew[]
  reviews Review[]
}

model Favorite{
  id Int @id @default(autoincrement())
  userId Int 
  movieId Int 

  user User @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id])  

  createdAt DateTime @default(now())
  @@unique([movieId,userId])
}

model Genre{
  id Int @id @default(autoincrement())
  name GenreEnum @unique
  movies Movie[] @relation("MovieGenres")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model TopCast{
  id Int @id @default(autoincrement())
  name String
  character String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])
}

model TopCrew{
  id Int @id @default(autoincrement())
  name String
  role CrewRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])
}

model Review{
  id Int @id @default(autoincrement())
  author String
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])  
}