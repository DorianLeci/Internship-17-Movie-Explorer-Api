generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CrewRole {
  DIRECTOR        @map("Director")
  PRODUCER        @map("Producer")
  WRITER          @map("Writer")
  EDITOR          @map("Editor")
  COMPOSER        @map("Composer")
  CINEMATOGRAPHER @map("Cinematographer")
}

enum GenreEnum {
  ACTION    @map("Action")
  ADVENTURE @map("Adventure")
  ANIMATION @map("Animation")
  COMEDY    @map("Comedy")
  CRIME     @map("Crime")
  DOCUMENTARY @map("Documentary")
  DRAMA     @map("Drama")
  FAMILY    @map("Family")
  FANTASY   @map("Fantasy")
  HISTORY   @map("History")
  HORROR    @map("Horror")
  MUSIC     @map("Music")
  MYSTERY   @map("Mystery")
  ROMANCE   @map("Romance")
  SCI_FI    @map("Sci-Fi")
  THRILLER  @map("Thriller")
  WAR       @map("War")
  WESTERN   @map("Western")
}

model Movie{
  id Int @id @default(autoincrement())
  title String
  description String
  runtime Int  
  rating Float
  popularity Float
  posterUrl String
  trailerUrl String
  releaseDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  genres Genre[] @relation("MovieGenres")

  favorite Favorite?
  topCast TopCast[]
  topCrew TopCrew[]
  reviews Review[]
}

model Favorite{
  id Int @id @default(autoincrement())
  movieId Int @unique
  movie Movie @relation(fields: [movieId], references: [id])  
  createdAt DateTime @default(now())
}

model Genre{
  id Int @id @default(autoincrement())
  name GenreEnum @unique
  movies Movie[] @relation("MovieGenres")
}

model TopCast{
  id Int @id @default(autoincrement())
  character String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  actorId Int
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])
  actor Actor @relation(fields: [actorId],references: [id])
}

model TopCrew{
  id Int @id @default(autoincrement())
  role CrewRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  crewMemberId Int
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])
  crewMember CrewMember @relation(fields: [crewMemberId],references: [id])
}

model Review{
  id Int @id @default(autoincrement())
  author String
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  movieId Int
  movie Movie @relation(fields: [movieId], references: [id])  
}

model Actor{
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  topCast TopCast[]
}

model CrewMember{
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  topCrew TopCrew[]
}
